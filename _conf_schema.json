{
    "api_key": {
        "description": "MiniMax Token Plan API Key",
        "type": "string",
        "hint": "请前往 MiniMax 开放平台获取 API Key。这是调用用量查询接口的必需凭证。",
        "obvious_hint": true,
        "default": "",
        "category": "minimax"
    },
    "region": {
        "description": "API 版本",
        "type": "string",
        "hint": "国内版使用 minimaxi.com，国际版使用 platform.minimax.io。",
        "obvious_hint": false,
        "default": "国内",
        "options": [
            "国内",
            "国际"
        ],
        "category": "minimax"
    },
    "group_id": {
        "description": "Group ID（国际版必填）",
        "type": "string",
        "hint": "仅国际版需要填写，用于指定查询的分组。",
        "obvious_hint": false,
        "default": "",
        "category": "minimax"
    },
    "whitelist": {
        "description": "白名单用户 SID 列表，为空则允许所有用户",
        "type": "list",
        "hint": "配置允许使用此插件的用户 SID 列表，留空则允许所有用户。",
        "obvious_hint": false,
        "default": [],
        "category": "minimax"
    },
    "show_year": {
        "description": "是否显示年份",
        "type": "bool",
        "hint": "开启后在时间显示中包含年份（如 2026-04-10），默认关闭。",
        "obvious_hint": false,
        "default": false,
        "category": "display"
    },
    "show_first_model_only": {
        "description": "仅显示第一个模型的用量",
        "type": "bool",
        "hint": "开启后仅展示第一个模型的用量信息，隐藏其他模型的展示。关闭（默认）则显示所有模型的用量。",
        "obvious_hint": false,
        "default": false,
        "category": "display"
    }
}